{
  "name": "@crguezl/json2jison",
  "version": "0.6.5-223",
  "description": "Converts json grammar definitions to jison's own format",
  "main": "json2jison.js",
  "scripts": {
    "test": "mocha --check-leaks --globals assert tests/",
    "test-nyc": "rm -rf ./coverage/ && nyc --reporter=lcov --reporter=html --reporter=text -- mocha --check-leaks --globals assert tests/",
    "pub": "npm publish --access public",
    "npm-update": "ncu -a --packageFile=package.json && rm -f package-lock.json",
    "npm-install": "npm install",
    "bump": "cd ../../ && node __patch_version_in_js.js",
    "superclean": "rm -rf node_modules/ && rm -f package-lock.json"
  },
  "keywords": [
    "jison",
    "json",
    "grammar",
    "parser",
    "generator"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git://github.com/GerHobbelt/json2jison.git"
  },
  "author": {
    "name": "Zach Carter",
    "email": "zach@carter.name",
    "url": "http://zaa.ch"
  },
  "license": "MIT",
  "bin": "./cli.js",
  "engines": {
    "node": ">=8.0"
  },
  "dependencies": {
    "commander": "11.1.0"
  },
  "devDependencies": {
    "chai": "4.2.0",
    "mocha": "6.2.2"
  }
}
