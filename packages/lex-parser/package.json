{
  "author": {
    "name": "Zach Carter",
    "email": "zach@carter.name",
    "url": "http://zaa.ch"
  },
  "name": "@crguezl/lex-parser",
  "version": "0.6.5-223",
  "description": "A parser for lexical grammars used by jison",
  "main": "dist/lex-parser-cjs-es5.js",
  "module": "lex-parser.js",
  "scripts": {
    "build": "jison -m es -o lex-parser.js lex.y lex.l && mkdir -p dist && rollup -c && babel dist/lex-parser-cjs.js -o dist/lex-parser-cjs-es5.js",
    "test": "mocha --timeout 18000 --check-leaks --globals assert tests/",
    "test-nyc": "rm -rf ./coverage/ && nyc --reporter=lcov --reporter=html --reporter=text -- mocha --timeout 18000 --check-leaks --globals assert tests/",
    "pub": "npm publish --access public",
    "npm-update": "ncu -a --packageFile=package.json && rm -f package-lock.json",
    "npm-install": "npm install",
    "bump": "cd ../../ && node __patch_version_in_js.js",
    "clean": "rm -f lex-parser.js && rm -rf dist/",
    "superclean": "npm run clean && rm -rf node_modules/ && rm -f package-lock.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GerHobbelt/lex-parser.git"
  },
  "keywords": [
    "lexical",
    "grammar",
    "parser",
    "jison"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=8.0"
  },
  "dependencies": {
    "@crguezl/xregexp": "4.2.0-30",
    "jison-helpers-lib": "0.6.5-223"
  },
  "devDependencies": {
    "@babel/cli": "7.7.0",
    "@babel/preset-env": "7.7.1",
    "babel-preset-modern-browsers": "14.0.0",
    "chai": "4.2.0",
    "jison-gho": "0.6.1-216",
    "mocha": "6.2.2",
    "rollup-plugin-node-resolve": "5.2.0",
    "rollup": "1.27.2"
  }
}