{
  "author": {
    "name": "Zach Carter",
    "email": "zach@carter.name",
    "url": "http://zaa.ch"
  },
  "contributors": [
    "Ger Hobbelt <ger@hobbelt.com>",
    "Casiano Rodriguez-Leon<crguezl@ull.edu.es>"
  ],
  "name": "jisonull",
  "description": "A parser generator with a Bison/YACC-similar API (derived off zaach/jison repo)",
  "version": "0.6.5-223",
  "license": "MIT",
  "keywords": [
    "jison",
    "bison",
    "yacc",
    "parser",
    "generator",
    "lexer",
    "flex",
    "tokenizer",
    "compiler"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/crguezl/jisonull.git"
  },
  "bugs": {
    "email": "jison@librelist.com",
    "url": "https://github.com/crguezl/jisonull/issues"
  },
  "main": "dist/jison-cjs-es5.js",
  "module": "lib/jison.js",
  "bin": {
    "jison": "dist/cli-cjs.js"
  },
  "engines": {
    "node": ">=8.0"
  },
  "dependencies": {
    "ast-util": "0.6.0",
    "@crguezl/json5": "2.1.0-48",
    "@crguezl/nomnom": "1.8.4-30",
    "recast": "0.20.4",
    "@crguezl/xregexp": "4.4.0-32"
  },
  "devDependencies": {
    "@babel/cli": "7.12.1",
    "@babel/core": "7.12.3",
    "@babel/preset-env": "7.12.1",
    "@crguezl/benchmark": "2.1.4-33",
    "@crguezl/debug": "4.1.1-5",
    "@crguezl/js-yaml": "3.13.1-6",
    "@crguezl/live-server": "1.3.1-28",
    "babel-preset-modern-browsers": "15.0.2",
    "browserify": "17.0.0",
    "chai": "4.2.0",
    "cross-env": "7.0.2",
    "get-stdin": "8.0.0",
    "globby": "11.0.1",
    "istanbul": "0.4.5",
    "jison-gho": "0.6.1-216",
    "mocha": "8.2.1",
    "nyc": "15.1.0",
    "rollup": "2.33.1",
    "rollup-plugin-commonjs": "10.1.0",
    "rollup-plugin-node-resolve": "5.2.0",
    "uglify-js": "3.11.5",
    "unicode-12.0.0": "0.8.0",
    "unicode-3.0.0": "0.7.5",
    "unicode-4.0.0": "0.7.5"
  },
  "scripts": {
    "build:rollup": "mkdir -p dist && rollup -c && rollup -c rollup.config-cli.js",
    "build:transpile": "babel dist/jison-cjs.js -o dist/jison-cjs-es5.js && babel dist/jison-umd.js -o dist/jison-umd-es5.js && babel dist/cli-cjs.js -o dist/cli-cjs-es5.js && babel dist/cli-umd.js -o dist/cli-umd-es5.js && node ../../__patch_nodebang_in_js.js",
    "build": "npm run build:rollup && npm run build:transpile",
    "sync": "npm run build",
    "regen": "npm run build",
    "clean": "rm -rf dist coverage .nyc_output"
  },
  "homepage": "https://github.com/crguezl/jisonull/blob/main/docs/README.md"
}
