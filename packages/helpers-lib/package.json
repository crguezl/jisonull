{
  "name": "jison-helpers-lib",
  "version": "0.6.5-223",
  "description": "Helper functions shared among the jison repositories (jison, ebnf-parser, lex-parser, jison-lex)",
  "main": "dist/helpers-lib-cjs-es5.js",
  "module": "index.js",
  "scripts": {
    "build": "mkdir -p dist && rollup -c && babel dist/helpers-lib-cjs.js -o dist/helpers-lib-cjs-es5.js && babel dist/helpers-lib-umd.js -o dist/helpers-lib-umd-es5.js",
    "test": "mocha --timeout 18000 --check-leaks --globals assert tests/",
    "test-nyc": "rm -rf ./coverage/ && nyc --reporter=lcov --reporter=html --reporter=text -- mocha --timeout 18000 --check-leaks --globals assert tests/",
    "pub": "npm publish --access public",
    "npm-update": "ncu -a --packageFile=package.json && rm -f package-lock.json",
    "npm-install": "npm install",
    "bump": "cd ../../ && node __patch_version_in_js.js",
    "clean": "rm -rf dist/",
    "superclean": "npm run clean && rm -rf node_modules/ && rm -f package-lock.json"
  },
  "keywords": [
    "jison",
    "json",
    "grammar",
    "parser",
    "generator"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/GerHobbelt/jison-helpers-lib.git"
  },
  "author": {
    "name": "Ger Hobbelt",
    "email": "ger@hobbelt.com",
    "url": "http://hobbelt.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=8.0"
  },
  "dependencies": {
    "ast-util": "0.6.0",
    "recast": "0.18.5",
    "@crguezl/xregexp": "4.4.0-32"
  },
  "devDependencies": {
    "@babel/cli": "7.7.0",
    "@babel/preset-env": "7.7.1",
    "babel-preset-modern-browsers": "14.0.0",
    "chai": "4.2.0",
    "mocha": "6.2.2",
    "rollup-plugin-node-resolve": "5.2.0",
    "rollup": "1.27.2"
  }
}
